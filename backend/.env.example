# ─────────────────────────────────────────────────────────────────────────────
# LeadPulse — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=LeadPulse
DEBUG=false
ENVIRONMENT=development          # development | production
SECRET_KEY=replace-with-openssl-rand-hex-32

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # Keep secret — full DB access

# ── Facebook / Meta App ───────────────────────────────────────────────────────
# Found in: developers.facebook.com → Your App → Settings → Basic
FACEBOOK_APP_ID=your-app-id
FACEBOOK_APP_SECRET=your-app-secret
FACEBOOK_WEBHOOK_VERIFY_TOKEN=choose-a-random-secret-string
FACEBOOK_API_VERSION=v19.0

# ── CORS (comma-separated origins) ───────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","https://app.leadpulse.io"]

# ── Redis (optional — for multi-server SSE, not needed for single server) ────
REDIS_URL=redis://localhost:6379
