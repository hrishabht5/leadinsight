# ─────────────────────────────────────────────────────────────────────────────
# LeadPulse Frontend — Environment Variables
# Copy this file to .env and fill in real values.
# ─────────────────────────────────────────────────────────────────────────────

# ── API Backend URL ──────────────────────────────────────────────────────────
# Leave empty for dev (Vite proxy handles it).
# Set to your production API URL for deployed builds.
VITE_API_URL=

# ── Facebook App ID ──────────────────────────────────────────────────────────
# Found in: developers.facebook.com → Your App → Settings → Basic
VITE_FACEBOOK_APP_ID=your-app-id-here
